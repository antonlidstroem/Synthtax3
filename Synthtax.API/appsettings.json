{
    "ConnectionStrings": {
        // SEC-06 FIX: Encrypt=False och Trust Server Certificate=False är ersatta med
        // Encrypt=True. Anslutningen krypteras nu via TLS.
        // Sätt TrustServerCertificate=True ENBART i lokala dev-miljöer (LocalDB).
        "DefaultConnection": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=SynthtaxDb;Integrated Security=True;Connect Timeout=30;Encrypt=True;TrustServerCertificate=True;Application Intent=ReadWrite;Multi Subnet Failover=False"
    },
    "JwtSettings": {
        // SEC-08: Ersätt med ett starkt, slumpmässigt värde i produktion.
        // Generera: openssl rand -base64 48
        // Sätt via miljövariabel: JwtSettings__SecretKey=<värde>
        "SecretKey": "CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48_MINIMUM_32_CHARS",
        "Issuer": "Synthtax.API",
        "Audience": "Synthtax.WPF",
        "AccessTokenExpiryMinutes": 60,
        "RefreshTokenExpiryDays": 30
    },
    "CiCd": {
        // Sätt via miljövariabel: CiCd__ApiKey=<värde>
        "ApiKey": "CHANGE_ME_SET_VIA_ENVIRONMENT_VARIABLE"
    },
    "CacheCleanup": {
        "IntervalMinutes": 60
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
        }
    },
    // ARCH-06 FIX: AllowedHosts begränsas. Ersätt med faktisk domän i produktion.
    // "*" tillåter host header injection.
    "AllowedHosts": "localhost",
    "Cors": {
        // SEC-03 FIX: Origins läses härifrån av ApiServiceExtensions.
        // Lägg till produktionsdomain här eller via Cors__AllowedOrigins__0 env-var.
        "AllowedOrigins": [ "http://localhost:5000", "https://localhost:5001" ]
    },
    "Seeding": {
        // SEC-01 FIX: Dessa lösenord ska ALDRIG loggas.
        // Sätt via miljövariabel: Seeding__AdminPassword=<värde>
        "AdminPassword": "CHANGE_ME_SET_VIA_ENVIRONMENT_VARIABLE",
        "DemoPassword": "CHANGE_ME_SET_VIA_ENVIRONMENT_VARIABLE"
    },



    "Jwt": {
        "SecretKey": "MIN-HEMLIGA-NYCKEL-MINST-32-TECKEN-LANG",
        "Issuer": "synthtax",
        "Audience": "synthtax-api",
        "AccessTokenExpiryMinutes": 60,
        "RefreshTokenExpiryDays": 30
    },

    "ConnectionStrings": {
        "Redis": "localhost:6379" // Valfritt — aktiverar SignalR-backplane
    },
    "SignalR": {
        "HeartbeatIntervalSeconds": 30
    }
}
