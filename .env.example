# ──────────────────────────────────────────────────────────────────────────────
# Synthtax – Miljövariabelexempel
# Kopiera denna fil till .env och fyll i riktiga värden.
# LÄGG INTE .env i Git-historiken — den finns redan i .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# SQL Server SA-lösenord (minst 8 tecken, kräver stor/liten bokstav + siffra + special)
MSSQL_SA_PASSWORD=CHANGE_ME_Strong#Password1

# JWT-signatur — minst 32 slumpmässiga tecken
# Generera: openssl rand -base64 48
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48

# Seed-lösenord för inbyggda konton
ADMIN_PASSWORD=CHANGE_ME_Admin@Synthtax1!
DEMO_PASSWORD=CHANGE_ME_Demo@Synthtax1!

# CI/CD API-nyckel (används av ApiKeyAttribute)
CICD_API_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
