<Window x:Class="Synthtax.WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Synthtax – Login"
        Width="420" Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="12" ClipToBounds="True">
        <Grid>
            <!-- Background gradient -->
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1A2744" Offset="0"/>
                    <GradientStop Color="#2A3F6F" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Decorative circle -->
            <Ellipse Width="280" Height="280"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-80,-80,0" Opacity="0.08">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#3B7DD8" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <StackPanel Margin="48,52,48,40" VerticalAlignment="Center">

                <!-- Logo area -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Border Width="36" Height="36" CornerRadius="8"
                            Background="#3B7DD8" Margin="0,0,10,0">
                        <TextBlock Text="S" FontSize="18" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Synthtax" FontSize="24" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="Kodintelligens" FontSize="13"
                           Foreground="#8899BB" Margin="0,0,0,36"/>

                <!-- Username -->
                <TextBlock Text="Användarnamn" Foreground="#8899BB"
                           FontSize="11" FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <Border CornerRadius="8" Background="#FFFFFF15"
                        BorderBrush="#FFFFFF25" BorderThickness="1"
                        Margin="0,0,0,16">
                    <TextBox x:Name="UsernameBox"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             Foreground="White" CaretBrush="White"
                             BorderThickness="0"
                             Padding="12,10"
                             FontSize="14"/>
                </Border>

                <!-- Password -->
                <TextBlock Text="Lösenord" Foreground="#8899BB"
                           FontSize="11" FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <Border CornerRadius="8" Background="#FFFFFF15"
                        BorderBrush="#FFFFFF25" BorderThickness="1"
                        Margin="0,0,0,28">
                    <PasswordBox x:Name="PasswordBox"
                                 Background="Transparent"
                                 Foreground="White" CaretBrush="White"
                                 BorderThickness="0"
                                 Padding="12,10"
                                 FontSize="14"/>
                </Border>

                <!-- Error message -->
                <Border Background="#FF3B3B20" CornerRadius="6"
                        Padding="12,8" Margin="0,0,0,16"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#FF8080" FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Login button -->
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoginCommand}"
                        Height="44" FontSize="14">
                    <Grid>
                        <TextBlock Text="Logga in"
                                   Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibility}}"/>
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Loggar in..." FontSize="13"/>
                        </StackPanel>
                    </Grid>
                </Button>

            </StackPanel>

            <!-- Drag to move -->
            <Rectangle Fill="Transparent" MouseLeftButtonDown="OnDragWindow"
                       Height="52" VerticalAlignment="Top"/>

            <!-- Close button -->
            <Button Content="✕" Width="32" Height="32"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,10,10,0"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#88AABB" Cursor="Hand"
                    Click="OnClose"/>
        </Grid>
    </Border>
</Window>
