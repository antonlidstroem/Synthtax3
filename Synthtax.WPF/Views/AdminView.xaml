<UserControl x:Class="Synthtax.WPF.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrls="clr-namespace:Synthtax.WPF.Controls" 
             Background="{StaticResource SurfaceBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitle}" Text="Administration"/>
                <TextBlock Text="Hantera användare, roller, modulåtkomst och audit-logg."
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
            </StackPanel>
            <Button Style="{StaticResource PrimaryButton}" Content="+ Ny användare"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Command="{Binding CreateUserCommand}" Height="34"/>
        </Grid>

        <!-- Tabs -->
        <ctrls:SpacedStackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton Content="Användare"  IsChecked="{Binding ShowUsers}"    GroupName="adminTabs"/>
            <RadioButton Content="Audit-logg" IsChecked="{Binding ShowAuditLog}" GroupName="adminTabs"/>
        </ctrls:SpacedStackPanel>

        <!-- ── Users panel ─────────────────────────────────────────────── -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0"
                Visibility="{Binding ShowUsers, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <ctrls:SpacedStackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,10" >
                    <TextBox Width="200"
                             Text="{Binding UserSearch, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Sök användare..."/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Aktivera"   Height="30"
                            Command="{Binding SetActiveCommand}" CommandParameter="True"
                            IsEnabled="{Binding SelectedUser, Converter={StaticResource NullToVisibility}, ConverterParameter=inverse}"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Inaktivera" Height="30"
                            Command="{Binding SetActiveCommand}" CommandParameter="False"
                            IsEnabled="{Binding SelectedUser, Converter={StaticResource NullToVisibility}, ConverterParameter=inverse}"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Återst. lösenord" Height="30"
                            Command="{Binding ResetPasswordCommand}"
                            IsEnabled="{Binding SelectedUser, Converter={StaticResource NullToVisibility}, ConverterParameter=inverse}"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Moduler" Height="30"
                            Command="{Binding EditModulesCommand}"
                            IsEnabled="{Binding SelectedUser, Converter={StaticResource NullToVisibility}, ConverterParameter=inverse}"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Ta bort" Height="30"
                            Command="{Binding DeleteUserCommand}" Foreground="#E53935"
                            IsEnabled="{Binding SelectedUser, Converter={StaticResource NullToVisibility}, ConverterParameter=inverse}"/>
                </ctrls:SpacedStackPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Användarnamn"  Binding="{Binding UserName}"  Width="150"/>
                        <DataGridTextColumn Header="Fullständigt namn" Binding="{Binding FullName}" Width="170"/>
                        <DataGridTextColumn Header="E-post"        Binding="{Binding Email}"     Width="*"/>
                        <DataGridTextColumn Header="Roll"          Binding="{Binding RoleDisplay}" Width="90"/>
                        <DataGridTextColumn Header="Senast inloggad"
                                            Binding="{Binding LastLoginAt, Converter={StaticResource DateTimeFormat}}"
                                            Width="140"/>

                        <!-- Status badge -->
                        <DataGridTemplateColumn Header="Status" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="6,2" Margin="4,2"
                                            HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="Aktiv"/>
                                                    <Setter Property="Foreground" Value="#1DB36B"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Text"       Value="Inaktiv"/>
                                                            <Setter Property="Foreground" Value="#E53935"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ── Audit log panel ─────────────────────────────────────────── -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0"
                Visibility="{Binding ShowAuditLog, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ctrls:SpacedStackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,10">
                    <TextBox Width="180"
                             Text="{Binding AuditSearch, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Filtrera logg..."/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Ladda fler" Height="30"
                            Command="{Binding LoadMoreAuditCommand}"/>
                </ctrls:SpacedStackPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding AuditLogs}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tidpunkt"
                                            Binding="{Binding OccurredAt, Converter={StaticResource DateTimeFormat}}"
                                            Width="140"/>
                        <DataGridTextColumn Header="Handling"  Binding="{Binding Action}"       Width="160"/>
                        <DataGridTextColumn Header="Resurstyp" Binding="{Binding ResourceType}" Width="120"/>
                        <DataGridTextColumn Header="Detaljer"  Binding="{Binding Details}"      Width="*"/>
                        <DataGridTextColumn Header="IP"        Binding="{Binding IpAddress}"    Width="130"/>

                        <!-- Success indicator -->
                        <DataGridTemplateColumn Header="OK" Width="55">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock HorizontalAlignment="Center" FontSize="14">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"       Value="✓"/>
                                                <Setter Property="Foreground" Value="#1DB36B"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Success}" Value="False">
                                                        <Setter Property="Text"       Value="✗"/>
                                                        <Setter Property="Foreground" Value="#E53935"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
