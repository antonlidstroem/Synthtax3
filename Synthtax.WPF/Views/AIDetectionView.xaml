<UserControl x:Class="Synthtax.WPF.Views.AIDetectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrls="clr-namespace:Synthtax.WPF.Controls"
             Background="{StaticResource SurfaceBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Style="{StaticResource PageTitle}" Text="AI-detektering"/>
            <TextBlock Text="Heuristisk analys av AI-genererade kodmönster: XML-doc-täthet, generiska variabelnamn, överdriven null-guard etc."
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
        </StackPanel>

        <!-- Path input -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ctrls:HintTextBox Grid.Column="0"
                         Text="{Binding SolutionPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,10,0"
                           Hint="Lokal sökväg till .sln-fil eller GitHub/GitLab-URL..."/>
                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                        Content="Bläddra..." Margin="0,0,8,0"
                        Command="{Binding BrowseCommand}"/>
                <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                        Content="Analysera" MinWidth="110"
                        Command="{Binding AnalyzeCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            </Grid>
        </Border>

        <!-- Summary cards -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="TOTAL POÄNG"/>
                    <TextBlock Text="{Binding OverallScore, Converter={StaticResource ScoreToPercent}}"
                               FontSize="32" FontWeight="Bold"
                               Foreground="{Binding OverallScore, Converter={StaticResource ScoreToBrush}}"/>
                    <TextBlock Text="{Binding OverallVerdict}" FontSize="12"
                               Foreground="{Binding OverallScore, Converter={StaticResource ScoreToBrush}}"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="FILER ANALYSERADE"/>
                    <TextBlock Text="{Binding FilesAnalyzed}" FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="HÖG POÄNG"/>
                    <TextBlock Text="{Binding FilesHighScore}" FontSize="32" FontWeight="Bold"
                               Foreground="#E53935"/>
                    <TextBlock Text="≥ 65% sannolikhet" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Filter controls -->
            <Border Grid.Column="3" Style="{StaticResource Card}" Padding="14,12" MinWidth="200">
                <ctrls:SpacedStackPanel >
                    <TextBlock Style="{StaticResource SectionHeader}" Text="FILTER"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Sök fil..." FontSize="12"/>
                    <Separator Margin="0,4"/>
                    <RadioButton Content="Alla filer"          IsChecked="{Binding ShowAll}"      GroupName="aiTabs"/>
                    <RadioButton Content="Bara höga (≥ 65%)"   IsChecked="{Binding ShowHighOnly}" GroupName="aiTabs"/>
                </ctrls:SpacedStackPanel>
            </Border>
        </Grid>

        <!-- Main: file list + signals detail -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- File results grid -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding HasData, Converter={StaticResource InverseBoolToVisibility}}">
                        <TextBlock Text="🤖" FontSize="48" HorizontalAlignment="Center"
                                   Opacity="0.25" Margin="0,0,0,12"/>
                        <TextBlock Text="Ange sökväg och kör analys"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" FontSize="13"/>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding FilteredFiles}"
                              SelectedItem="{Binding SelectedFile}"
                              Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Fil" Binding="{Binding FileName}" Width="*"/>

                            <!-- Score bar -->
                            <DataGridTemplateColumn Header="AI-sannolikhet" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="8,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="44"/>
                                            </Grid.ColumnDefinitions>
                                            <ProgressBar Grid.Column="0" Height="8"
                                                             Minimum="0" Maximum="1"
                                                             Value="{Binding AILikelihoodScore}"
                                                             Foreground="{Binding AILikelihoodScore, Converter={StaticResource ScoreToBrush}}"
                                                             Background="{StaticResource SurfaceAltBrush}"
                                                             BorderThickness="0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding AILikelihoodScore, Converter={StaticResource ScoreToPercent}}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Foreground="{Binding AILikelihoodScore, Converter={StaticResource ScoreToBrush}}"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Verdict badge -->
                            <DataGridTemplateColumn Header="Utlåtande" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="7,3" Margin="4,2"
                                                HorizontalAlignment="Center"
                                                Background="{Binding AILikelihoodScore, Converter={StaticResource ScoreToBrush}}">
                                            <TextBlock Text="{Binding Verdict}"
                                                       Foreground="White"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Signaler"
                                                Binding="{Binding Signals.Count}" Width="75"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- Signals panel -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <!-- No selection -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding SelectedFile, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Text="Välj en fil för att se detaljerade signaler."
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="13" TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Signals detail -->
                <Grid Visibility="{Binding SelectedFile, Converter={StaticResource NullToVisibility}, ConverterParameter=inverse}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- File header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="{Binding SelectedFile.FileName}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding SelectedFile.FilePath}"/>

                        <!-- Big score circle -->
                        <Grid Width="80" Height="80" Margin="0,12,0,12" HorizontalAlignment="Left">
                            <Ellipse Stroke="{StaticResource SurfaceAltBrush}" StrokeThickness="6"/>
                            <Ellipse Stroke="{Binding SelectedFile.AILikelihoodScore, Converter={StaticResource ScoreToBrush}}"
                                     StrokeThickness="6" Opacity="0.85"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding SelectedFile.AILikelihoodScore, Converter={StaticResource ScoreToPercent}}"
                                           FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"
                                           Foreground="{Binding SelectedFile.AILikelihoodScore, Converter={StaticResource ScoreToBrush}}"/>
                                <TextBlock Text="{Binding SelectedFile.Verdict}"
                                           FontSize="9" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                            </StackPanel>
                        </Grid>

                        <Separator Margin="0,0,0,8"/>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="DETEKTERADE SIGNALER"/>
                    </StackPanel>

                    <!-- Signals list -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Signals}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" CornerRadius="8" Padding="12,10"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background"   Value="#F8F9FC"/>
                                                <Setter Property="BorderBrush"  Value="#E8EAEF"/>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Signal type + weight -->
                                            <Grid Grid.Row="0">
                                                <TextBlock Text="{Binding SignalType}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <Border HorizontalAlignment="Right"
                                                        Background="{StaticResource AccentBrush}"
                                                        CornerRadius="4" Padding="6,2">
                                                    <TextBlock Text="{Binding Weight, StringFormat=×{0:F1}}"
                                                               FontSize="10" Foreground="White"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>

                                            <!-- Description -->
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Description}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,4"/>

                                            <!-- Evidence -->
                                            <Border Grid.Row="2"
                                                    Background="#F0F5FF" CornerRadius="4"
                                                    Padding="8,5"
                                                    Visibility="{Binding Evidence, Converter={StaticResource NullToVisibility}, ConverterParameter=inverse}">
                                                <TextBlock Text="{Binding Evidence}"
                                                           FontFamily="Cascadia Code, Consolas"
                                                           FontSize="10"
                                                           Foreground="#3B7DD8"
                                                           TextWrapping="Wrap"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
