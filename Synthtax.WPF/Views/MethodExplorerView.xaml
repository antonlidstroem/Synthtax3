<UserControl x:Class="Synthtax.WPF.Views.MethodExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrls="clr-namespace:Synthtax.WPF.Controls"
             Background="{StaticResource SurfaceBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Style="{StaticResource PageTitle}" Text="Metodutforskaren"/>
            <TextBlock Text="Sök, filtrera och sortera alla metoder i solution med signatur, komplexitet och dokumentation."
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
        </StackPanel>

        <!-- Path input -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ctrls:HintTextBox Grid.Column="0"
                         Text="{Binding SolutionPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,10,0" ToolTip="Sökväg till .sln-fil"
                           Hint="Lokal sökväg till .sln-fil eller GitHub/GitLab-URL..."/>
                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                        Content="Bläddra..." Margin="0,0,8,0"
                        Command="{Binding BrowseCommand}"/>
                <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                        Content="Analysera" MinWidth="110"
                        Command="{Binding AnalyzeCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Stats + filter bar -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="TOTALT"/>
                    <TextBlock Text="{Binding TotalMethods}" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="metoder" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="ASYNC"/>
                    <TextBlock Text="{Binding AsyncCount}" FontSize="28" FontWeight="Bold" Foreground="#1DB36B"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="STATISKA"/>
                    <TextBlock Text="{Binding StaticCount}" FontSize="28" FontWeight="Bold" Foreground="#8B5CF6"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="SNITT KOMPLEX."/>
                    <TextBlock Text="{Binding AvgComplexity}" FontSize="28" FontWeight="Bold" Foreground="#F59E0B"/>
                </StackPanel>
            </Border>

            <!-- Filters -->
            <Border Grid.Column="4" Style="{StaticResource Card}" Padding="14,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ctrls:SpacedStackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox Width="160"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Sök metod eller klass..."/>
                        <ComboBox Width="160"
                                  ItemsSource="{Binding ClassNames}"
                                  SelectedItem="{Binding ClassFilter}"/>
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="Rensa" Height="30" Padding="10,0"
                                Command="{Binding ClearFiltersCommand}"/>
                    </ctrls:SpacedStackPanel>
                    <ctrls:SpacedStackPanel Grid.Row="1" Orientation="Horizontal" >
                        <CheckBox Content="Bara publika"  IsChecked="{Binding ShowOnlyPublic}"/>
                        <CheckBox Content="Bara async"    IsChecked="{Binding ShowOnlyAsync}"/>
                        <CheckBox Content="Bara statiska" IsChecked="{Binding ShowOnlyStatic}"/>
                        <CheckBox Content="Sortera på komplexitet" IsChecked="{Binding SortByComplexity}"/>
                    </ctrls:SpacedStackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Results: grid + detail panel -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Methods grid -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <!-- Empty state -->
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding HasData, Converter={StaticResource InverseBoolToVisibility}}">
                        <TextBlock Text="⚙" FontSize="48" HorizontalAlignment="Center"
                                   Opacity="0.25" Margin="0,0,0,12"/>
                        <TextBlock Text="Ange en sökväg och kör analys"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" FontSize="13"/>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding FilteredMethods}"
                              SelectedItem="{Binding SelectedMethod}"
                              Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Klass"      Binding="{Binding ClassName}"    Width="160"/>
                            <DataGridTextColumn Header="Metod"      Binding="{Binding MethodName}"   Width="*"/>
                            <DataGridTextColumn Header="Return"     Binding="{Binding ReturnType}"   Width="110"/>
                            <DataGridTextColumn Header="LOC"        Binding="{Binding LinesOfCode}"  Width="55"/>
                            <DataGridTemplateColumn Header="Komplex." Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="6,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>
                                            <ProgressBar Grid.Column="0" Height="6"
                                                             Minimum="0" Maximum="20"
                                                             Value="{Binding CyclomaticComplexity}"
                                                             Foreground="{Binding CyclomaticComplexity, Converter={StaticResource MaintainabilityToBrush}}"
                                                             Background="{StaticResource SurfaceAltBrush}"
                                                             BorderThickness="0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding CyclomaticComplexity}"
                                                       FontSize="11" HorizontalAlignment="Right"
                                                       Foreground="{Binding CyclomaticComplexity, Converter={StaticResource MaintainabilityToBrush}}"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Async" Width="55">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center" FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value=""/>
                                                    <Setter Property="Foreground" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAsync}" Value="True">
                                                            <Setter Property="Text"       Value="⚡"/>
                                                            <Setter Property="Foreground" Value="#1DB36B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- Detail panel -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <!-- No selection -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding SelectedMethod, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Text="Välj en metod" Foreground="{StaticResource TextMutedBrush}"
                               FontSize="13" TextAlignment="Center"/>
                </StackPanel>

                <!-- Method details -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding SelectedMethod, Converter={StaticResource NullToVisibility}, ConverterParameter=inverse}">
                    <StackPanel DataContext="{Binding SelectedMethod}" Margin="4,0">

                        <!-- Method name + badges -->
                        <TextBlock Text="{Binding MethodName}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,4"/>

                        <ctrls:SpacedStackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Background="{StaticResource AccentBrush}" CornerRadius="4" Padding="6,2"
                                    Visibility="{Binding IsPublic, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="public" Foreground="White" FontSize="10" FontFamily="Cascadia Code, Consolas"/>
                            </Border>
                            <Border Background="#1DB36B" CornerRadius="4" Padding="6,2"
                                    Visibility="{Binding IsAsync, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="async" Foreground="White" FontSize="10" FontFamily="Cascadia Code, Consolas"/>
                            </Border>
                            <Border Background="#8B5CF6" CornerRadius="4" Padding="6,2"
                                    Visibility="{Binding IsStatic, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="static" Foreground="White" FontSize="10" FontFamily="Cascadia Code, Consolas"/>
                            </Border>
                        </ctrls:SpacedStackPanel>

                        <!-- Full signature -->
                        <TextBlock Style="{StaticResource SectionHeader}" Text="SIGNATUR"/>
                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="6"
                                Padding="10,8" Margin="0,4,0,16">
                            <TextBlock Text="{Binding FullSignature}"
                                       FontFamily="Cascadia Code, Consolas"
                                       FontSize="11" Foreground="#3B7DD8"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Class / Namespace -->
                        <TextBlock Style="{StaticResource SectionHeader}" Text="KLASS"/>
                        <TextBlock Text="{Binding ClassName}" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,12"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="NAMESPACE"/>
                        <TextBlock Text="{Binding NamespaceName}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,16"/>

                        <!-- Metrics row -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource SurfaceAltBrush}"
                                    CornerRadius="6" Padding="10,8" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionHeader}" Text="LOC"/>
                                    <TextBlock Text="{Binding LinesOfCode}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="{StaticResource SurfaceAltBrush}"
                                    CornerRadius="6" Padding="10,8" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionHeader}" Text="KOMPLEX."/>
                                    <TextBlock Text="{Binding CyclomaticComplexity}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{Binding CyclomaticComplexity, Converter={StaticResource MaintainabilityToBrush}}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="{StaticResource SurfaceAltBrush}"
                                    CornerRadius="6" Padding="10,8">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionHeader}" Text="RAD"/>
                                    <TextBlock Text="{Binding StartLine}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Parameters -->
                        <TextBlock Style="{StaticResource SectionHeader}" Text="PARAMETRAR"/>
                        <ItemsControl ItemsSource="{Binding Parameters}" Margin="0,4,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F0F5FF" CornerRadius="4"
                                            Padding="8,4" Margin="0,2">
                                        <TextBlock Text="{Binding}"
                                                   FontFamily="Cascadia Code, Consolas"
                                                   FontSize="11" Foreground="#3B7DD8"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- XML doc summary -->
                        <StackPanel Visibility="{Binding XmlDocSummary, Converter={StaticResource NullToVisibility}, ConverterParameter=inverse}">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="DOKUMENTATION"/>
                            <Border Background="#FFFBEB" CornerRadius="6" Padding="10,8" Margin="0,4,0,0"
                                    BorderBrush="#FDE68A" BorderThickness="1">
                                <TextBlock Text="{Binding XmlDocSummary}"
                                           FontSize="12" Foreground="#92400E"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>

                        <!-- File path -->
                        <TextBlock Style="{StaticResource SectionHeader}" Text="FIL" Margin="0,16,0,4"/>
                        <TextBlock Text="{Binding FileName}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding FilePath}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
