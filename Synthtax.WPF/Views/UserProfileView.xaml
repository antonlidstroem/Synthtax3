<UserControl x:Class="Synthtax.WPF.Views.UserProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24" MaxWidth="640">

            <TextBlock Style="{StaticResource PageTitle}" Text="Min profil" Margin="0,0,0,6"/>
            <TextBlock Text="Hantera dina kontouppgifter och inställningar."
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,24"/>

            <!-- Profile card -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="KONTOINFORMATION" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Fullständigt namn" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Grid.Column="1" Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="E-postadress" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Grid.Column="1" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Användarnamn" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Grid.Column="1" Text="{Binding UserName}" IsEnabled="False"
                                 Opacity="0.6"/>
                    </Grid>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Roll" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Role}" VerticalAlignment="Center"
                                   FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                    </Grid>

                    <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"
                            Content="Spara ändringar" Command="{Binding SaveProfileCommand}"/>
                </StackPanel>
            </Border>

            <!-- Preferences card -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="INSTÄLLNINGAR" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Tema" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <ComboBox Grid.Column="1" SelectedItem="{Binding Theme}"
                                  ItemsSource="{Binding ThemeOptions}" Width="160" HorizontalAlignment="Left"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Språk" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <ComboBox Grid.Column="1" SelectedItem="{Binding Language}"
                                  ItemsSource="{Binding LanguageOptions}" Width="160" HorizontalAlignment="Left"/>
                    </Grid>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="E-postnotiser" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding EmailNotifications}"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"
                            Content="Spara inställningar" Command="{Binding SavePreferencesCommand}"/>
                </StackPanel>
            </Border>

            <!-- Change password card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="BYTA LÖSENORD" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Nuvarande lösenord" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <PasswordBox Grid.Column="1" x:Name="CurrentPwBox" Padding="10,7"
                                     BorderThickness="1.5" BorderBrush="{StaticResource BorderBrush}"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Nytt lösenord" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <PasswordBox Grid.Column="1" x:Name="NewPwBox" Padding="10,7"
                                     BorderThickness="1.5" BorderBrush="{StaticResource BorderBrush}"/>
                    </Grid>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Bekräfta lösenord" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <PasswordBox Grid.Column="1" x:Name="ConfirmPwBox" Padding="10,7"
                                     BorderThickness="1.5" BorderBrush="{StaticResource BorderBrush}"/>
                    </Grid>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                               FontSize="12" Margin="0,0,0,12"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"/>

                    <TextBlock Text="Lösenord ändrat!" Foreground="{StaticResource SuccessBrush}"
                               FontSize="12" Margin="0,0,0,12"
                               Visibility="{Binding PasswordChanged, Converter={StaticResource BoolToVisibility}}"/>

                    <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"
                            Content="Byt lösenord" Command="{Binding ChangePasswordCommand}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
