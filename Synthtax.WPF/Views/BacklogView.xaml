<UserControl x:Class="Synthtax.WPF.Views.BacklogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrls="clr-namespace:Synthtax.WPF.Controls"
             Background="{StaticResource SurfaceBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title + actions -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitle}" Text="Backlog"/>
                <TextBlock Text="Tekniska ärenden kopplade till kodfynd eller manuellt skapade."
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
            </StackPanel>
            <ctrls:SpacedStackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Bottom" >
                <Button Style="{StaticResource SecondaryButton}" Content="CSV"
                        Command="{Binding ExportCsvCommand}" Padding="10,6" Height="32"/>
                <Button Style="{StaticResource SecondaryButton}" Content="JSON"
                        Command="{Binding ExportJsonCommand}" Padding="10,6" Height="32"/>
                <Button Style="{StaticResource PrimaryButton}" Content="+ Nytt ärende"
                        Command="{Binding CreateItemCommand}" Height="32"/>
            </ctrls:SpacedStackPanel>
        </Grid>

        <!-- Filter bar -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <ctrls:SpacedStackPanel Orientation="Horizontal" >
                <TextBox Width="220"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Sök i titel..."/>
                <ComboBox Width="120" ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding FilterStatus}" DisplayMemberPath="Label"/>
                <ComboBox Width="120" ItemsSource="{Binding PriorityOptions}"
                          SelectedItem="{Binding FilterPriority}" DisplayMemberPath="Label"/>
                <ComboBox Width="140" ItemsSource="{Binding CategoryOptions}"
                          SelectedItem="{Binding FilterCategory}" DisplayMemberPath="Label"/>
                <CheckBox Content="Bara mina ärenden" IsChecked="{Binding MyItemsOnly}"
                          VerticalAlignment="Center"/>
                <Button Style="{StaticResource SecondaryButton}" Content="Rensa"
                        Command="{Binding ClearFiltersCommand}" Height="32" Padding="12,0"/>
            </ctrls:SpacedStackPanel>
        </Border>

        <!-- Data grid -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedItem}"
                      MouseDoubleClick="OnRowDoubleClick">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Redigera" Command="{Binding EditItemCommand}"
                                  CommandParameter="{Binding SelectedItem}"/>
                        <Separator/>
                        <MenuItem Header="Ta bort" Command="{Binding DeleteItemCommand}"
                                  CommandParameter="{Binding SelectedItem}"
                                  Foreground="#E53935"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Titel"     Binding="{Binding Title}"  Width="*"/>

                    <!-- Status badge -->
                    <DataGridTemplateColumn Header="Status" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="6,2" Margin="4,2"
                                        HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Done">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                    <Setter Property="Background" Value="#F5F5F5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Priority badge -->
                    <DataGridTemplateColumn Header="Prioritet" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Priority, Converter={StaticResource SeverityToBrush}}"
                                        CornerRadius="4" Padding="6,2" Margin="4,2"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Priority}" Foreground="White"
                                               FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Kategori"  Binding="{Binding Category}"  Width="110"/>
                    <DataGridTextColumn Header="Deadline"
                                        Binding="{Binding Deadline, Converter={StaticResource DateTimeFormat}, ConverterParameter='yyyy-MM-dd'}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Skapad av" Binding="{Binding CreatedByUserName}" Width="120"/>

                    <!-- Edit / Delete buttons -->
                    <DataGridTemplateColumn Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ctrls:SpacedStackPanel Orientation="Horizontal" HorizontalAlignment="Center" >
                                    <Button Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Width="24" Height="24" ToolTip="Redigera"
                                            Command="{Binding DataContext.EditItemCommand,
                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="✏" FontSize="13"/>
                                    </Button>
                                    <Button Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Width="24" Height="24" ToolTip="Ta bort"
                                            Command="{Binding DataContext.DeleteItemCommand,
                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="🗑" FontSize="13"/>
                                    </Button>
                                </ctrls:SpacedStackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
