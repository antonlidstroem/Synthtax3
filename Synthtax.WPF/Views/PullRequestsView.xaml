<UserControl x:Class="Synthtax.WPF.Views.PullRequestsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrls="clr-namespace:Synthtax.WPF.Controls"
             Background="{StaticResource SurfaceBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Style="{StaticResource PageTitle}" Text="Pull Requests"/>
            <TextBlock Text="Visa och filtrera PR:er. Demo-data visas om ingen API-integration är konfigurerad."
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
        </StackPanel>

        <!-- URL input -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding RepositoryUrl, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,10,0"
                         ToolTip="Repo-URL (valfritt – visar demo-data utan URL)"/>
                <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                        Content="Ladda PR:er" MinWidth="130"
                        Command="{Binding LoadCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Stats + filter -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid>
            <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="ÖPPNA"/>
                    <TextBlock Text="{Binding OpenCount}" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
            </Border>
            </Grid>
            <Grid>
                <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="SAMMANSLAGNA"/>
                        <TextBlock Text="{Binding MergedCount}" FontSize="28" FontWeight="Bold" Foreground="#1DB36B"/>
                    </StackPanel>
                </Border>
            </Grid>
            <Grid>
            <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="STÄNGDA"/>
                    <TextBlock Text="{Binding ClosedCount}" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </Border>
            </Grid>

            <!-- Filter panel -->
            <Grid>
            <Border Grid.Column="3" Style="{StaticResource Card}" Padding="14,12" MinWidth="220">
                <ctrls:SpacedStackPanel >
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Sök titel, författare..." FontSize="12"/>
                    <ctrls:SpacedStackPanel Orientation="Horizontal" >
                        <CheckBox Content="Öppna"    IsChecked="{Binding ShowOpen}"/>
                        <CheckBox Content="Merged"   IsChecked="{Binding ShowMerged}"/>
                        <CheckBox Content="Stängda"  IsChecked="{Binding ShowClosed}"/>
                    </ctrls:SpacedStackPanel>
                    <Button Style="{StaticResource SecondaryButton}" Content="Rensa"
                            Height="28" Padding="10,0" Command="{Binding ClearFiltersCommand}"/>
                </ctrls:SpacedStackPanel>
            </Border>
            </Grid>
        </Grid>

        <!-- PR list + detail -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- PR grid -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding HasData, Converter={StaticResource InverseBoolToVisibility}}">
                        <TextBlock Text="🔀" FontSize="48" HorizontalAlignment="Center"
                                   Opacity="0.25" Margin="0,0,0,12"/>
                        <TextBlock Text="Klicka på 'Ladda PR:er' för att visa pull requests"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" FontSize="13"/>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding FilteredPRs}"
                              SelectedItem="{Binding SelectedPr}"
                              Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"         Binding="{Binding Id}"           Width="45"/>
                            <DataGridTextColumn Header="Titel"     Binding="{Binding Title}"         Width="*"/>
                            <DataGridTextColumn Header="Författare" Binding="{Binding Author}"       Width="100"/>
                            <DataGridTextColumn Header="Mål-branch" Binding="{Binding TargetBranch}" Width="110"/>

                            <!-- Status badge -->
                            <DataGridTemplateColumn Header="Status" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="6,2" Margin="4,2"
                                                HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Merged">
                                                            <Setter Property="Background" Value="#E8F5E9"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Closed">
                                                            <Setter Property="Background" Value="#F5F5F5"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Skapad"
                                                Binding="{Binding CreatedAt, Converter={StaticResource DateTimeFormat}, ConverterParameter='dd MMM'}"
                                                Width="70"/>
                            <DataGridTextColumn Header="+/-"
                                                Width="70">
                                <DataGridTextColumn.Binding>
                                    <MultiBinding StringFormat="+{0}/-{1}">
                                        <Binding Path="Insertions"/>
                                        <Binding Path="Deletions"/>
                                    </MultiBinding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- PR detail panel -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding SelectedPr, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Text="Välj en PR" Foreground="{StaticResource TextMutedBrush}"
                               FontSize="13" TextAlignment="Center"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding SelectedPr, Converter={StaticResource NullToVisibility}, ConverterParameter=inverse}">
                    <ctrls:SpacedStackPanel DataContext="{Binding SelectedPr}" >

                        <!-- PR title + ID -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Background="#E3F2FD" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                <TextBlock Text="{Binding Id, StringFormat='#{0}'}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"/>
                            </Border>
                            <Border CornerRadius="4" Padding="6,2">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Merged">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Closed">
                                                <Setter Property="Background" Value="#F5F5F5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Status}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Text="{Binding Title}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <Separator Margin="0,0,0,16"/>

                        <!-- Branch flow -->
                        <TextBlock Style="{StaticResource SectionHeader}" Text="BRANCH"/>
                        <ctrls:SpacedStackPanel Orientation="Horizontal" Margin="0,4,0,16" >
                            <Border Background="#F0F5FF" CornerRadius="4" Padding="8,4">
                                <TextBlock Text="{Binding SourceBranch}"
                                           FontFamily="Cascadia Code, Consolas"
                                           FontSize="11" Foreground="{StaticResource AccentBrush}"/>
                            </Border>
                            <TextBlock Text="→" FontSize="14"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                            <Border Background="#F0FFF4" CornerRadius="4" Padding="8,4">
                                <TextBlock Text="{Binding TargetBranch}"
                                           FontFamily="Cascadia Code, Consolas"
                                           FontSize="11" Foreground="#1DB36B"/>
                            </Border>
                        </ctrls:SpacedStackPanel>

                        <!-- Author + dates -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionHeader}" Text="FÖRFATTARE"/>
                                <TextBlock Text="{Binding Author}" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1">
                                <TextBlock Style="{StaticResource SectionHeader}" Text="SKAPAD"/>
                                <TextBlock Text="{Binding CreatedAt, Converter={StaticResource DateTimeFormat}}"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Change stats -->
                        <TextBlock Style="{StaticResource SectionHeader}" Text="ÄNDRINGAR"/>
                        <Grid Margin="0,4,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource SurfaceAltBrush}"
                                    CornerRadius="6" Padding="8,6" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Filer" FontSize="10"
                                               Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding FilesChanged}"
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="#E8F5E9"
                                    CornerRadius="6" Padding="8,6" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Tillägg" FontSize="10" Foreground="#1DB36B"/>
                                    <TextBlock Text="{Binding Insertions, StringFormat='+{0}'}"
                                               FontSize="18" FontWeight="Bold" Foreground="#1DB36B"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="#FFEBEE"
                                    CornerRadius="6" Padding="8,6">
                                <StackPanel>
                                    <TextBlock Text="Borttagn." FontSize="10" Foreground="#E53935"/>
                                    <TextBlock Text="{Binding Deletions, StringFormat='-{0}'}"
                                               FontSize="18" FontWeight="Bold" Foreground="#E53935"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Reviewers -->
                        <TextBlock Style="{StaticResource SectionHeader}" Text="GRANSKARE"/>
                        <ItemsControl ItemsSource="{Binding Reviewers}" Margin="0,4,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SurfaceAltBrush}"
                                            CornerRadius="4" Padding="8,4" Margin="0,2">
                                        <TextBlock Text="{Binding}" FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Labels -->
                        <StackPanel Visibility="{Binding Labels.Count, Converter={StaticResource NullToVisibility}, ConverterParameter=inverse}">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="ETIKETTER"/>
                            <ItemsControl ItemsSource="{Binding Labels}" Margin="0,4,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F0F5FF" CornerRadius="4"
                                                Padding="8,3" Margin="0,0,6,4">
                                            <TextBlock Text="{Binding}" FontSize="11"
                                                       Foreground="{StaticResource AccentBrush}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Description -->
                        <StackPanel Visibility="{Binding Description, Converter={StaticResource NullToVisibility}, ConverterParameter=inverse}"
                                    Margin="0,16,0,0">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="BESKRIVNING"/>
                            <TextBlock Text="{Binding Description}"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </ctrls:SpacedStackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
