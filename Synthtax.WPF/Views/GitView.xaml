<UserControl x:Class="Synthtax.WPF.Views.GitView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrls="clr-namespace:Synthtax.WPF.Controls"
             Background="{StaticResource SurfaceBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Style="{StaticResource PageTitle}" Text="Git-analys"/>
            <TextBlock Text="Commits, brancher, fil-churn och bus factor via LibGit2Sharp."
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding RepositoryPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,10,0" ToolTip="Sökväg till Git-repo"/>
                <ComboBox Grid.Column="1" Width="100" Margin="0,0,8,0"
                          SelectedItem="{Binding MaxCommits}"
                          ItemsSource="{Binding CommitLimits}"/>
                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}"
                        Content="Bläddra..." Margin="0,0,8,0" Command="{Binding BrowseCommand}"/>
                <Button Grid.Column="3" Style="{StaticResource PrimaryButton}"
                        Content="Analysera" MinWidth="110" Command="{Binding AnalyzeCommand}"/>
            </Grid>
        </Border>

        <!-- Summary stats -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="COMMITS"/>
                    <TextBlock Text="{Binding TotalCommits, Converter={StaticResource NumberFormat}}"
                               FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="4,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="BRANCHER"/>
                    <TextBlock Text="{Binding TotalBranches}" FontSize="32" FontWeight="Bold" Foreground="#8B5CF6"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="4,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="BIDRAGSGIVARE"/>
                    <TextBlock Text="{Binding TotalContributors}" FontSize="32" FontWeight="Bold" Foreground="#1DB36B"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource StatCard}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="AKTIV BRANCH"/>
                    <TextBlock Text="{Binding CurrentBranch}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Tabs for commits / churn / bus factor -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <ctrls:SpacedStackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,12" >
                    <RadioButton Content="Commits"      IsChecked="{Binding ShowCommits}"   GroupName="gitTabs"/>
                    <RadioButton Content="Fil-churn"    IsChecked="{Binding ShowChurn}"     GroupName="gitTabs"/>
                    <RadioButton Content="Bus Factor"   IsChecked="{Binding ShowBusFactor}" GroupName="gitTabs"/>
                    <RadioButton Content="Brancher"     IsChecked="{Binding ShowBranches}"  GroupName="gitTabs"/>
                </ctrls:SpacedStackPanel>
                <DataGrid Grid.Row="1" ItemsSource="{Binding CurrentRows}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="SHA"         Binding="{Binding ShortSha}"    Width="80"/>
                        <DataGridTextColumn Header="Författare"  Binding="{Binding AuthorName}"  Width="140"/>
                        <DataGridTextColumn Header="Datum"       Binding="{Binding AuthoredAt, Converter={StaticResource DateTimeFormat}}" Width="130"/>
                        <DataGridTextColumn Header="Meddelande"  Binding="{Binding Message}"     Width="*"/>
                        <DataGridTextColumn Header="+/-"         Binding="{Binding ChangeSummary}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
