<UserControl x:Class="Synthtax.WPF.Views.CodeAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrls="clr-namespace:Synthtax.WPF.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Synthtax.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CodeAnalysisViewModel}"
             Background="{StaticResource SurfaceBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title row -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Style="{StaticResource PageTitle}" Text="Kodanalys"/>
            <TextBlock Text="Analyserar lösa metoder, döda variabler och onödiga usings via Roslyn."
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
        </StackPanel>

        <!-- Path input + action -->
        <ctrls:SolutionInputBar Grid.Row="1"/>

        <!-- Stat cards -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="TOTALT"/>
                    <TextBlock Text="{Binding TotalIssues, Converter={StaticResource NumberFormat}}"
                               FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="problem hittade" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="4,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="LÅNGA METODER"/>
                    <TextBlock Text="{Binding LongMethodCount, Converter={StaticResource NumberFormat}}"
                               FontSize="32" FontWeight="Bold" Foreground="#F59E0B"/>
                    <TextBlock Text="metoder &gt; 50 rader" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="4,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="DÖDA VARIABLER"/>
                    <TextBlock Text="{Binding DeadVariableCount, Converter={StaticResource NumberFormat}}"
                               FontSize="32" FontWeight="Bold" Foreground="#E53935"/>
                    <TextBlock Text="oanvända lokala vars" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource StatCard}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="ONÖDIGA USINGS"/>
                    <TextBlock Text="{Binding UnnecessaryUsingCount, Converter={StaticResource NumberFormat}}"
                               FontSize="32" FontWeight="Bold" Foreground="#8B5CF6"/>
                    <TextBlock Text="can be removed" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Results with tabs -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Tab header -->
                <ctrls:SpacedStackPanel Grid.Row="0" Orientation="Horizontal"
                            Margin="16,12" >
                    <RadioButton Content="Långa metoder" IsChecked="{Binding ShowLongMethods}"
                                 Style="{StaticResource {x:Type RadioButton}}"
                                 GroupName="tabs"/>
                    <RadioButton Content="Döda variabler" IsChecked="{Binding ShowDeadVariables}"
                                 GroupName="tabs"/>
                    <RadioButton Content="Onödiga usings" IsChecked="{Binding ShowUnnecessaryUsings}"
                                 GroupName="tabs"/>

                    <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="8,0"/>

                    <!-- Export -->
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="CSV" Padding="10,4" Height="28"
                            Command="{Binding ExportCsvCommand}"/>
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="JSON" Padding="10,4" Height="28"
                            Command="{Binding ExportJsonCommand}"/>
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="PDF" Padding="10,4" Height="28"
                            Command="{Binding ExportPdfCommand}"/>
                </ctrls:SpacedStackPanel>

                <!-- DataGrid -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding CurrentIssues}"
                          SelectedItem="{Binding SelectedIssue}"
                          Margin="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fil"       Binding="{Binding FileName}"    Width="180"/>
                        <DataGridTextColumn Header="Rad"       Binding="{Binding LineNumber}"   Width="60"/>
                        <DataGridTextColumn Header="Metod"     Binding="{Binding MethodName}"   Width="160"/>
                        <DataGridTextColumn Header="Beskrivning" Binding="{Binding Description}" Width="*"/>
                        <DataGridTemplateColumn Header="Allvarlighet" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Severity, Converter={StaticResource SeverityToBrush}}"
                                            CornerRadius="4" Padding="6,2" HorizontalAlignment="Center"
                                            Margin="4,2">
                                        <TextBlock Text="{Binding Severity}" Foreground="White"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Status / busy indicator -->
                <Border Grid.Row="2" Background="{StaticResource SurfaceAltBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                        Padding="16,8">
                    <Grid>
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="⟳" FontSize="14" Margin="0,0,8,0"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                                   Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibility}}"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource ErrorBrush}" FontSize="12"
                                   HorizontalAlignment="Right"
                                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
