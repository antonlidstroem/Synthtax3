<UserControl x:Class="Synthtax.WPF.Views.MetricsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Style="{StaticResource PageTitle}" Text="Metrics"/>
            <TextBlock Text="LOC, cyklomatisk komplexitet och underhållsindex per fil."
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ctrls:HintTextBox Grid.Column="0" Text="{Binding SolutionPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,10,0"
                           Hint="Lokal sökväg till .sln-fil eller GitHub/GitLab-URL..."/>
                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Bläddra..."
                        Margin="0,0,8,0" Command="{Binding BrowseCommand}"/>
                <Button Grid.Column="2" Style="{StaticResource PrimaryButton}" Content="Analysera"
                        MinWidth="110" Command="{Binding AnalyzeCommand}"/>
            </Grid>
        </Border>

        <!-- Summary stat cards -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="TOTALA LOC"/>
                    <TextBlock Text="{Binding TotalLoc, Converter={StaticResource NumberFormat}}"
                               FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="4,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="FILER"/>
                    <TextBlock Text="{Binding TotalFiles, Converter={StaticResource NumberFormat}}"
                               FontSize="32" FontWeight="Bold" Foreground="#8B5CF6"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="4,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="SNITT KOMPLEXITET"/>
                    <TextBlock Text="{Binding AvgComplexity, StringFormat=N1}"
                               FontSize="32" FontWeight="Bold" Foreground="#F59E0B"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource StatCard}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="SNITT MI"/>
                    <TextBlock Text="{Binding AvgMaintainability, StringFormat=N1}"
                               FontSize="32" FontWeight="Bold"
                               Foreground="{Binding AvgMaintainability, Converter={StaticResource MaintainabilityToBrush}}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- File metrics grid -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding FileMetrics}" SelectedItem="{Binding SelectedFile}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Fil"          Binding="{Binding FileName}"                      Width="200"/>
                    <DataGridTextColumn Header="Projekt"      Binding="{Binding ProjectName}"                   Width="140"/>
                    <DataGridTextColumn Header="LOC"          Binding="{Binding LinesOfCode}"                   Width="70"/>
                    <DataGridTextColumn Header="Metoder"      Binding="{Binding NumberOfMethods}"               Width="80"/>
                    <DataGridTextColumn Header="Klasser"      Binding="{Binding NumberOfClasses}"               Width="80"/>
                    <DataGridTextColumn Header="Komplexitet"  Binding="{Binding AverageCyclomaticComplexity, StringFormat=N1}" Width="110"/>
                    <DataGridTemplateColumn Header="MI" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="6,0">
                                    <Border Width="{Binding MaintainabilityIndex, Converter={StaticResource NumberFormat}}"
                                            MaxWidth="60" Height="6" CornerRadius="3"
                                            Background="{Binding MaintainabilityIndex, Converter={StaticResource MaintainabilityToBrush}}"/>
                                    <TextBlock Text="{Binding MaintainabilityIndex, StringFormat=N0}"
                                               Margin="6,0,0,0" FontSize="11"
                                               Foreground="{Binding MaintainabilityIndex, Converter={StaticResource MaintainabilityToBrush}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
