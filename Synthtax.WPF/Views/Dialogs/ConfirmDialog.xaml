<Window x:Class="Synthtax.WPF.Views.Dialogs.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrls="clr-namespace:Synthtax.WPF.Controls"
        Title="Bekräfta"
        Width="400" Height="220"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Border CornerRadius="10" ClipToBounds="True"
            BorderBrush="#D1D5E0" BorderThickness="1">
        <Border.Background><SolidColorBrush Color="#FFFFFF"/></Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#A0B0C8" BlurRadius="24" ShadowDepth="4" Opacity="0.45"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#F8F9FC"
                    BorderBrush="#D1D5E0" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="OnDragWindow">
                <TextBlock Text="{Binding Title}"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="#1A2744" VerticalAlignment="Center"
                           Margin="20,0"/>
            </Border>

            <!-- Message -->
            <StackPanel Grid.Row="1" Margin="24,20" VerticalAlignment="Center">
                <TextBlock Text="{Binding Message}"
                           FontSize="13" Foreground="#5A6480"
                           TextWrapping="Wrap" LineHeight="20"/>
            </StackPanel>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="#F8F9FC"
                    BorderBrush="#D1D5E0" BorderThickness="0,1,0,0">
                <ctrls:SpacedStackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="24,0" >
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="{Binding CancelLabel}"
                            Width="90" Height="36"
                            Click="OnCancel"/>
                    <Button x:Name="ConfirmBtn"
                            Width="110" Height="36"
                            Content="{Binding ConfirmLabel}"
                            Click="OnConfirm">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDangerous}" Value="True">
                                        <Setter Property="Background" Value="#E53935"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </ctrls:SpacedStackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
