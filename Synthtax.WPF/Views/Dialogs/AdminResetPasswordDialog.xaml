<Window x:Class="Synthtax.WPF.Views.Dialogs.AdminResetPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrls="clr-namespace:Synthtax.WPF.Controls"
        Title="Återställ lösenord"
        Width="440" Height="320"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Border CornerRadius="10" ClipToBounds="True"
            BorderBrush="#D1D5E0" BorderThickness="1">
        <Border.Background><SolidColorBrush Color="#FFFFFF"/></Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#A0B0C8" BlurRadius="24" ShadowDepth="4" Opacity="0.45"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#F8F9FC"
                    BorderBrush="#D1D5E0" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="OnDragWindow">
                <Grid Margin="20,0">
                    <TextBlock Text="Återställ lösenord"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="#1A2744" VerticalAlignment="Center"/>
                    <Button Content="✕" Width="28" Height="28" HorizontalAlignment="Right"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#9AA3B8" Cursor="Hand" Click="OnClose"/>
                </Grid>
            </Border>

            <ctrls:SpacedStackPanel Grid.Row="1" Margin="24,20" >
                <TextBlock Text="{Binding InfoText}"
                           Foreground="#5A6480" FontSize="13"
                           TextWrapping="Wrap" Margin="0,0,0,20"/>

                <TextBlock Text="Nytt lösenord *" Style="{StaticResource SectionHeader}"/>
                <Border CornerRadius="6" BorderBrush="#D1D5E0" BorderThickness="1.5" Margin="0,0,0,14">
                    <PasswordBox x:Name="NewPwBox" Padding="10,7" BorderThickness="0" FontSize="13"/>
                </Border>

                <TextBlock Text="Bekräfta lösenord *" Style="{StaticResource SectionHeader}"/>
                <Border CornerRadius="6" BorderBrush="#D1D5E0" BorderThickness="1.5" Margin="0,0,0,14">
                    <PasswordBox x:Name="ConfirmPwBox" Padding="10,7" BorderThickness="0" FontSize="13"/>
                </Border>

                <Border Background="#FFEBEE" CornerRadius="6" Padding="12,8"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#E53935" FontSize="12"/>
                </Border>
            </ctrls:SpacedStackPanel>

            <Border Grid.Row="2" Background="#F8F9FC"
                    BorderBrush="#D1D5E0" BorderThickness="0,1,0,0">
                <ctrls:SpacedStackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="24,0" >
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="Avbryt" Width="90" Height="36" Click="OnClose"/>
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Återställ" Width="110" Height="36"
                            Command="{Binding ResetCommand}"/>
                </ctrls:SpacedStackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
