<Window x:Class="Synthtax.WPF.Views.Dialogs.AdminCreateUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrls="clr-namespace:Synthtax.WPF.Controls"
        Title="Ny användare"
        Width="480" Height="490"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Border CornerRadius="10" ClipToBounds="True"
            BorderBrush="#D1D5E0" BorderThickness="1">
        <Border.Background><SolidColorBrush Color="#FFFFFF"/></Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#A0B0C8" BlurRadius="24" ShadowDepth="4" Opacity="0.45"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#F8F9FC"
                    BorderBrush="#D1D5E0" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="OnDragWindow">
                <Grid Margin="20,0">
                    <TextBlock Text="Skapa ny användare"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="#1A2744" VerticalAlignment="Center"/>
                    <Button Content="✕" Width="28" Height="28" HorizontalAlignment="Right"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#9AA3B8" Cursor="Hand" Click="OnClose"/>
                </Grid>
            </Border>

            <!-- Form -->
            <ctrls:SpacedStackPanel Grid.Row="1" Margin="24,20" >

                <TextBlock Text="Fullständigt namn" Style="{StaticResource SectionHeader}"/>
                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>

                <TextBlock Text="Användarnamn *" Style="{StaticResource SectionHeader}"/>
                <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>

                <TextBlock Text="E-postadress *" Style="{StaticResource SectionHeader}"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>

                <TextBlock Text="Lösenord *" Style="{StaticResource SectionHeader}"/>
                <Border CornerRadius="6" BorderBrush="#D1D5E0" BorderThickness="1.5"
                        Margin="0,0,0,14">
                    <PasswordBox x:Name="PasswordBox" Padding="10,7" BorderThickness="0"
                                 FontSize="13"/>
                </Border>

                <TextBlock Text="Roll" Style="{StaticResource SectionHeader}"/>
                <ComboBox ItemsSource="{Binding RoleOptions}"
                          SelectedItem="{Binding SelectedRole}"
                          Margin="0,0,0,14"/>

                <!-- Error -->
                <Border Background="#FFEBEE" CornerRadius="6" Padding="12,8"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#E53935" FontSize="12" TextWrapping="Wrap"/>
                </Border>

            </ctrls:SpacedStackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F8F9FC"
                    BorderBrush="#D1D5E0" BorderThickness="0,1,0,0">
                <ctrls:SpacedStackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="24,0" >
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="Avbryt" Width="90" Height="36" Click="OnClose"/>
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Skapa" Width="110" Height="36"
                            Command="{Binding CreateCommand}"/>
                </ctrls:SpacedStackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
