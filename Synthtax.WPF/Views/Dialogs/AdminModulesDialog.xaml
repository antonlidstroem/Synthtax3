<Window x:Class="Synthtax.WPF.Views.Dialogs.AdminModulesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrls="clr-namespace:Synthtax.WPF.Controls"
        Title="Modulåtkomst"
        Width="440" Height="520"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Border CornerRadius="10" ClipToBounds="True"
            BorderBrush="#D1D5E0" BorderThickness="1">
        <Border.Background><SolidColorBrush Color="#FFFFFF"/></Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#A0B0C8" BlurRadius="24" ShadowDepth="4" Opacity="0.45"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#F8F9FC"
                    BorderBrush="#D1D5E0" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="OnDragWindow">
                <Grid Margin="20,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Modulåtkomst" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#1A2744"/>
                        <TextBlock Text="{Binding SubTitle}" FontSize="11" Foreground="#9AA3B8"/>
                    </StackPanel>
                    <Button Content="✕" Width="28" Height="28" HorizontalAlignment="Right"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#9AA3B8" Cursor="Hand" Click="OnClose"/>
                </Grid>
            </Border>

            <!-- Module list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,16">

                    <TextBlock Text="Välj vilka moduler användaren har tillgång till."
                               Foreground="#5A6480" FontSize="13"
                               TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <!-- Select All / None -->
                    <ctrls:SpacedStackPanel Orientation="Horizontal" Margin="0,0,0,12" >
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="Välj alla" Height="28" Padding="12,4"
                                Command="{Binding SelectAllCommand}"/>
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="Rensa alla" Height="28" Padding="12,4"
                                Command="{Binding ClearAllCommand}"/>
                    </ctrls:SpacedStackPanel>

                    <ItemsControl ItemsSource="{Binding ModuleItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" Padding="12,10"
                                        CornerRadius="8"
                                        BorderBrush="#E8EAEF" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="White"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                    <Setter Property="Background" Value="#F0F5FF"/>
                                                    <Setter Property="BorderBrush" Value="#3B7DD830"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                                   FontSize="16" Width="28"
                                                   VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0">
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#1A2744"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="11" Foreground="#9AA3B8"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding IsEnabled}"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Error -->
                    <Border Background="#FFEBEE" CornerRadius="6" Padding="12,8" Margin="0,8,0,0"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#E53935" FontSize="12"/>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F8F9FC"
                    BorderBrush="#D1D5E0" BorderThickness="0,1,0,0">
                <ctrls:SpacedStackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="24,0" >
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="Avbryt" Width="90" Height="36" Click="OnClose"/>
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Spara" Width="110" Height="36"
                            Command="{Binding SaveCommand}"/>
                </ctrls:SpacedStackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
