<Window x:Class="Synthtax.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrls="clr-namespace:Synthtax.WPF.Controls"
        Title="Synthtax"
        MinWidth="1100" MinHeight="680"
        Width="1400" Height="820"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="10" ClipToBounds="True"
            BorderBrush="#D1D5E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#A0B0C8" BlurRadius="24" ShadowDepth="4" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Left navigation sidebar -->
                <ColumnDefinition Width="220"/>
                <!-- Main content area -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── LEFT NAVIGATION SIDEBAR ───────────────────────── -->
            <Grid Grid.Column="0">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1A2744" Offset="0"/>
                        <GradientStop Color="#162038" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.RowDefinitions>
                    <RowDefinition Height="64"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- App Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="20,0">
                    <Border Width="30" Height="30" CornerRadius="7"
                            Background="#3B7DD8" Margin="0,0,10,0">
                        <TextBlock Text="S" FontSize="16" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Synthtax" FontSize="15" FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Kodintelligens" FontSize="10"
                                   Foreground="#5A7AAA"/>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="10,8,10,8">
                        <ItemsControl ItemsSource="{Binding NavItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="NavItemBorder"
                                            CornerRadius="7" Margin="0,2"
                                            Padding="12,9" Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#3B7DD820"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FFFFFF12"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.SelectNavItemCommand,
                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontSize="15" Width="22"
                                                       Foreground="#8899CC"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="13" Margin="8,0,0,0"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#99AABB"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom user info -->
                <Border Grid.Row="2" BorderBrush="#FFFFFF15" BorderThickness="0,1,0,0"
                        Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentUserName}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="{Binding CurrentUserRole}"
                                   FontSize="11" Foreground="#5A7AAA"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── MAIN CONTENT AREA ───────────────────────────────── -->
            <Grid Grid.Column="1">
                <Grid.Background>
                    <SolidColorBrush Color="#F8F9FC"/>
                </Grid.Background>
                <Grid.RowDefinitions>
                    <!-- Topbar -->
                    <RowDefinition Height="52"/>
                    <!-- Content -->
                    <RowDefinition Height="*"/>
                    <!-- Bottombar -->
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <!-- ── TOPBAR ──────────────────────────────────────── -->
                <Border Grid.Row="0"
                        Background="White"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="OnDragWindow">
                    <Grid Margin="20,0">
                        <!-- Breadcrumb / module name -->
                        <TextBlock Text="{Binding CurrentModuleLabel}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"/>

                        <!-- Right-side actions -->
                        <ctrls:SpacedStackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    >

                            <!-- Language toggle -->
                            <Button Style="{StaticResource SecondaryButton}"
                                    Padding="10,5" Height="30"
                                    Command="{Binding SwitchLanguageCommand}"
                                    CommandParameter="sv-SE"
                                    ToolTip="Svenska">
                                <TextBlock Text="SV" FontSize="11" FontWeight="SemiBold"/>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}"
                                    Padding="10,5" Height="30"
                                    Command="{Binding SwitchLanguageCommand}"
                                    CommandParameter="en-US"
                                    ToolTip="English">
                                <TextBlock Text="EN" FontSize="11" FontWeight="SemiBold"/>
                            </Button>

                            <Separator Width="1" Background="{StaticResource BorderBrush}"
                                       Margin="6,4"/>

                            <!-- Log out -->
                            <Button Style="{StaticResource SecondaryButton}"
                                    Padding="10,5" Height="30"
                                    Command="{Binding LogoutCommand}">
                                <TextBlock Text="Logga ut" FontSize="12"/>
                            </Button>

                            <Separator Width="1" Background="{StaticResource BorderBrush}"
                                       Margin="6,4"/>

                            <!-- Window controls -->
                            <Button Width="30" Height="30"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    Click="OnMinimize" Cursor="Hand"
                                    Content="─"/>
                            <Button Width="30" Height="30"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    Click="OnMaximize" Cursor="Hand"
                                    Content="□"/>
                            <Button Width="30" Height="30"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    Click="OnClose" Cursor="Hand"
                                    Content="✕"/>
                        </ctrls:SpacedStackPanel>
                    </Grid>
                </Border>

                <!-- ── CONTENT AREA ────────────────────────────────── -->
                <ContentPresenter Grid.Row="1"
                                  Content="{Binding CurrentView}"
                                  Margin="0"/>

                <!-- ── BOTTOM STATUS BAR ───────────────────────────── -->
                <Border Grid.Row="2"
                        Background="#EEF0F6"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0">
                    <Grid Margin="16,0">
                        <TextBlock Text="{Binding BacklogStatus}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding GlobalStatus}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
