<UserControl x:Class="Synthtax.WPF.Views.CommentExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrls="clr-namespace:Synthtax.WPF.Controls"
             Background="{StaticResource SurfaceBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Style="{StaticResource PageTitle}" Text="Kommentarsutforskaren"/>
            <TextBlock Text="Utforska alla kommentarer, TODO/FIXME-markeringar och #region-block i solution."
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
        </StackPanel>

        <!-- Path input -->
        <ctrls:SolutionInputBar Grid.Row="1"/>

        <!-- Stats -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="TOTALA"/>
                    <TextBlock Text="{Binding TotalComments, Converter={StaticResource NumberFormat}}"
                               FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="kommentarer" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="XML DOC"/>
                    <TextBlock Text="{Binding XmlDocCount}" FontSize="28" FontWeight="Bold" Foreground="#1DB36B"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="TODO / FIXME"/>
                    <TextBlock Text="{Binding TodoCount}" FontSize="28" FontWeight="Bold" Foreground="#F59E0B"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="REGIONER"/>
                    <TextBlock Text="{Binding RegionCount}" FontSize="28" FontWeight="Bold" Foreground="#8B5CF6"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main results area -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tab bar + search -->
                <Grid Grid.Row="0" Margin="16,10">
                    <ctrls:SpacedStackPanel Orientation="Horizontal" >
                        <RadioButton Content="Alla"        IsChecked="{Binding ShowAll}"    GroupName="cmTabs"/>
                        <RadioButton Content="TODO/FIXME"  IsChecked="{Binding ShowTodos}"  GroupName="cmTabs"/>
                        <RadioButton Content="XML Doc"     IsChecked="{Binding ShowXmlDoc}" GroupName="cmTabs"/>
                        <RadioButton Content="Regioner"    IsChecked="{Binding ShowRegions}" GroupName="cmTabs"/>
                    </ctrls:SpacedStackPanel>
                    <TextBox Width="220" HorizontalAlignment="Right"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Sök i kommentarer..."/>
                </Grid>

                <!-- Empty state -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding HasData, Converter={StaticResource InverseBoolToVisibility}}">
                    <TextBlock Text="💬" FontSize="48" HorizontalAlignment="Center"
                               Opacity="0.25" Margin="0,0,0,12"/>
                    <TextBlock Text="Kör en analys för att utforska kommentarer"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" FontSize="13"/>
                </StackPanel>

                <!-- Comments grid -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding DisplayComments}"
                          SelectedItem="{Binding SelectedComment}"
                          Visibility="{Binding ShowRegions, Converter={StaticResource InverseBoolToVisibility}}">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <!-- Highlight TODO/FIXME rows in yellow -->
                                <DataTrigger Binding="{Binding CommentType}" Value="Todo">
                                    <Setter Property="Background" Value="#FFFBEB"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fil"    Binding="{Binding FileName}"   Width="170"/>
                        <DataGridTextColumn Header="Rad"    Binding="{Binding LineNumber}"  Width="55"/>
                        <DataGridTemplateColumn Header="Typ" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="6,2" Margin="4,2" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E3F2FD"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CommentType}" Value="XmlDoc">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CommentType}" Value="MultiLine">
                                                        <Setter Property="Background" Value="#F3E5F5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding CommentType}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Associerad med" Binding="{Binding AssociatedMember}" Width="160"/>
                        <DataGridTextColumn Header="Innehåll"       Binding="{Binding Content}"          Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Regions grid -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding DisplayRegions}"
                          Visibility="{Binding ShowRegions, Converter={StaticResource BoolToVisibility}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fil"         Binding="{Binding FileName}"   Width="200"/>
                        <DataGridTextColumn Header="Regionnamn"  Binding="{Binding RegionName}" Width="*"/>
                        <DataGridTextColumn Header="Startar"     Binding="{Binding StartLine}"  Width="70"/>
                        <DataGridTextColumn Header="Slutar"      Binding="{Binding EndLine}"    Width="70"/>
                        <DataGridTextColumn Header="LOC"         Binding="{Binding LinesOfCode}" Width="65"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
