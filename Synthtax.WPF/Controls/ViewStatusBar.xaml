<UserControl x:Class="Synthtax.WPF.Controls.ViewStatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource SurfaceAltBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0"
            Height="30">
        <Grid Margin="16,0">
            <!-- Left: spinner + status message -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Spinning indicator (only when busy) -->
                <Grid Width="16" Height="16" Margin="0,0,8,0"
                      Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                    <Ellipse Stroke="{StaticResource SurfaceAltBrush}"
                             StrokeThickness="2.5"/>
                    <Ellipse Stroke="{StaticResource AccentBrush}"
                             StrokeThickness="2.5"
                             StrokeDashArray="4 8">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="MiniSpinner" CenterX="8" CenterY="8"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="MiniSpinner"
                                            Storyboard.TargetProperty="Angle"
                                            From="0" To="360" Duration="0:0:0.9"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </Grid>

                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>

            <!-- Right: error message -->
            <TextBlock Text="{Binding ErrorMessage}"
                       FontSize="11"
                       Foreground="{StaticResource ErrorBrush}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="400"/>
        </Grid>
    </Border>
</UserControl>
