<UserControl x:Class="Synthtax.WPF.Controls.SolutionInputBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrls="clr-namespace:Synthtax.WPF.Controls">

    <!--
        SolutionInputBar
        ════════════════
        Delad inmatningskontroll för sökväg/URL + Bläddra + Analysera.
        Används av: CodeAnalysisView, MetricsView, SecurityView,
                    StructureAnalysisView, MethodExplorerView,
                    CommentExplorerView, AIDetectionView, GitView.

        Bindningar (via DataContext = AnalysisViewModelBase):
          InputPath        ← text i fältet
          BrowseCommand    ← Bläddra-knappen
          AnalyzeCommand   ← Analysera-knappen (måste definieras i subklassens VM)
          IsRemoteUrl      ← visar URL-ikonen
          PathTypeHint     ← tooltip på typ-indikatorn
          IsBusy           ← inaktiverar Analysera-knappen
    -->

    <Border Style="{StaticResource Card}" Margin="0,0,0,16">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Typ-indikator (ikon) -->
                <ColumnDefinition Width="Auto"/>
                <!-- Textrutan -->
                <ColumnDefinition Width="*"/>
                <!-- Bläddra -->
                <ColumnDefinition Width="Auto"/>
                <!-- Analysera -->
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ── Ikonsymbol: lokal fil/mapp vs. URL ───────────────────── -->
            <Border Grid.Column="0"
                    Width="32" Height="32"
                    CornerRadius="6"
                    Margin="0,0,8,0"
                    ToolTip="{Binding PathTypeHint}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRemoteUrl}" Value="True">
                                <Setter Property="Background" Value="#E8F0FB"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <!-- Lokal ikon (standard) -->
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="14">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text"       Value="📄"/>
                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                            <Style.Triggers>
                                <!-- URL -->
                                <DataTrigger Binding="{Binding IsRemoteUrl}" Value="True">
                                    <Setter Property="Text"       Value="🌐"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                </DataTrigger>
                                <!-- Tomt fält -->
                                <DataTrigger Binding="{Binding InputPath}" Value="">
                                    <Setter Property="Text"       Value="📁"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                    <Setter Property="Opacity"    Value="0.4"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <!-- ── Textrutan ─────────────────────────────────────────────── -->
            <ctrls:HintTextBox
                Grid.Column="1"
                Text="{Binding InputPath, UpdateSourceTrigger=PropertyChanged}"
                Hint="Lokal sökväg till .sln-fil / Git-katalog eller GitHub-URL..."
                Margin="0,0,10,0"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                VerticalContentAlignment="Center">
                <ctrls:HintTextBox.InputBindings>
                    <!-- Kör analysen direkt på Enter -->
                    <KeyBinding Key="Return" Command="{Binding AnalyzeCommand}"/>
                </ctrls:HintTextBox.InputBindings>
            </ctrls:HintTextBox>

            <!-- ── Bläddra-knapp (dold om URL-läge) ─────────────────────── -->
            <Button
                Grid.Column="2"
                Style="{StaticResource SecondaryButton}"
                Content="Bläddra..."
                Margin="0,0,8,0"
                Command="{Binding BrowseCommand}"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                Visibility="{Binding IsRemoteUrl,
                    Converter={StaticResource InverseBoolToVisibility}}"/>

            <!-- Platshållare när URL-läge för att hålla layouten stabil -->
            <Border Grid.Column="2" Width="86" Margin="0,0,8,0"
                    Visibility="{Binding IsRemoteUrl,
                        Converter={StaticResource BoolToVisibility}}"/>

            <!-- ── Analysera-knapp ────────────────────────────────────────── -->
            <Button
                Grid.Column="3"
                Style="{StaticResource PrimaryButton}"
                MinWidth="110"
                Command="{Binding AnalyzeCommand}"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">

                <Grid>
                    <!-- Idle state -->
                    <TextBlock Text="Analysera"
                               Visibility="{Binding IsBusy,
                                   Converter={StaticResource InverseBoolToVisibility}}"/>

                    <!-- Busy state – mini-spinner -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsBusy,
                                    Converter={StaticResource BoolToVisibility}}">
                        <Grid Width="14" Height="14" Margin="0,0,6,0">
                            <Ellipse Stroke="#FFFFFF50" StrokeThickness="2"/>
                            <Ellipse Stroke="White" StrokeThickness="2"
                                     StrokeDashArray="4 8">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="BtnSpinner"
                                                     CenterX="7" CenterY="7"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation
                                                    Storyboard.TargetName="BtnSpinner"
                                                    Storyboard.TargetProperty="Angle"
                                                    From="0" To="360"
                                                    Duration="0:0:0.8"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                        </Grid>
                        <TextBlock Text="Analyserar..." FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Button>
        </Grid>
    </Border>
</UserControl>
